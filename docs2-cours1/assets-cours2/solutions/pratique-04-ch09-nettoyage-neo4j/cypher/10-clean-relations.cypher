// Methode 1 : effacer SEULEMENT les relations (les noeuds restent)
MATCH ()-[r]-()
DELETE r;

// Verification
MATCH (n) RETURN count(n) AS noeuds_restants;
MATCH ()-[r]-() RETURN count(r) AS relations_restantes;
