{
  "settings": {
    "number_of_shards":   1,
    "number_of_replicas": 0,
    "refresh_interval":   "-1"
  },
  "mappings": {
    "properties": {
      "date":     { "type": "date", "format": "yyyy-MM-dd" },
      "category": {
        "type": "text",
        "fields": { "keyword": { "type": "keyword" } }
      },
      "headline": {
        "type": "text",
        "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } }
      },
      "authors":  {
        "type": "text",
        "fields": { "keyword": { "type": "keyword" } }
      },
      "short_description": {
        "type": "text",
        "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } }
      },
      "link":     { "type": "keyword" }
    }
  }
}
